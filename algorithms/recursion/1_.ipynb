   "source": [
    "## №1 Сумма натуральных чисел (n=3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "05faa463",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "15\n"
     ]
    }
   ],
   "source": [
    "def sum(n):\n",
    "    \n",
    "    if n == 1:\n",
    "        return 1\n",
    "    \n",
    "    return n + sum(n - 1)\n",
    "\n",
    "n = 5\n",
    "print(sum(n))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "91ce1927",
   "metadata": {},
   "source": [
    "## №2 Факториал числа"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "4faca367",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "120\n"
     ]
    }
   ],
   "source": [
    "def fact(n: int) -> int:\n",
    "    if n == 0:\n",
    "        return 1\n",
    "    return n * fact(n-1)\n",
    "\n",
    "n = 5\n",
    "print(fact(n))"
   ]
  }
