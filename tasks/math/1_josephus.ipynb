   "source": [
    "def josephus(n, k):\n",
    "    m = list(range(1, n + 1))\n",
    "    ans = []\n",
    "    i = 0\n",
    "    while m:\n",
    "        i = (i + k - 1) % len(m)\n",
    "        ans.append(m.pop(i))\n",
    "    return ans\n",
    "\n",
    "print(josephus(5,3))"
   ]
